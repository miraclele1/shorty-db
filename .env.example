# ─── App ──────────────────────────────────────────────────────────────
# Public URL of the app. Used by Better Auth for callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment. Vercel sets this automatically in prod.
NODE_ENV=development


# ─── Database (Neon) ──────────────────────────────────────────────────
# Pooled connection — use for app queries (Drizzle in serverless).
# Get from: https://console.neon.tech → Project → Connection Details → Pooled.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/dbname?sslmode=require"

# Direct (unpooled) connection — use ONLY for migrations.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.neon.tech/dbname?sslmode=require"


# ─── Auth (Better Auth) ───────────────────────────────────────────────
# Random 32+ char secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Same as NEXT_PUBLIC_APP_URL
BETTER_AUTH_URL=http://localhost:3000


# ─── OAuth: Google ────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client.
# Authorized redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ─── Email (Resend) ───────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender. Use onboarding@resend.dev for local dev only.
EMAIL_FROM="RapidIT <noreply@rapidit.app>"


# ─── External APIs ────────────────────────────────────────────────────
# YouTube Data API v3
# https://console.cloud.google.com/apis/credentials
# Note: default quota is 10k units/day. Quota increase request lives in #infra.
YOUTUBE_API_KEY=


# ─── Observability ────────────────────────────────────────────────────
# Sentry — https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Required for source map upload — set in CI environment only,
# do NOT commit to local .env.local
SENTRY_AUTH_TOKEN=
